{
  "name": "vellum",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "a reading app that feels native everywhere",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "web:build": "VITE_BASE=/Vellum/ VITE_WEB_ABS=1 vite build",
    "preview": "vite preview",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:linux": "bash scripts/build-linux.sh",
    "tauri": "tauri",
    "mobile:sync": "vite build && cap sync",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "ios:build": "vite build && cap sync ios && cap build ios --scheme App",
    "cap": "cap"
  },
  "devDependencies": {
    "@capacitor/cli": "^6",
    "@tauri-apps/cli": "^2",
    "vite": "^6.0.5"
  },
  "dependencies": {
    "@capacitor/android": "^6",
    "@capacitor/core": "^6",
    "@capacitor/ios": "^6",
    "@fontsource/archivo": "^5",
    "@fontsource/ibm-plex-mono": "^5",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2"
  }
}
